<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="false">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_merchant"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_merchant" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/merchantBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/bg_surface"
        app:elevation="16dp"
        app:itemIconSize="24dp"
        app:itemIconTint="@color/bottom_nav_merchant_colors"
        app:itemTextColor="@color/bottom_nav_merchant_colors"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_merchant_bottom_nav" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
