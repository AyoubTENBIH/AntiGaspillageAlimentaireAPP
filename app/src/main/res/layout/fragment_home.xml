<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_screen_h">

        <!-- TopBar: location + notif -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingTop="@dimen/spacing_l"
            android:paddingBottom="@dimen/spacing_m">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_location_on_rounded"
                app:tint="@color/accent_primary" />

            <TextView
                android:id="@+id/locationText"
                style="@style/TextAppearance.SaveAt.H3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_s"
                android:text="@string/location_default" />

            <FrameLayout
                android:id="@+id/btnNotifications"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_circle_white"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center">

                <ImageView
                    android:id="@+id/notificationIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_notifications_rounded"
                    app:tint="@color/text_body" />
                <TextView
                    android:id="@+id/badgeNotifications"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-2dp"
                    android:layout_marginEnd="-2dp"
                    android:background="@drawable/bg_notification_badge"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:text="3"
                    tools:visibility="visible" />
            </FrameLayout>
        </LinearLayout>

        <!-- SearchBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_m">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search_rounded"
                app:tint="@color/text_secondary" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/searchEdit"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/spacing_s"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/search_hint"
                android:inputType="text"
                android:textColor="@color/text_body"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Banner promo -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="@dimen/spacing_m"
            app:cardBackgroundColor="@color/text_h1"
            app:cardCornerRadius="@dimen/radius_extra_large"
            app:cardElevation="@dimen/elevation_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        style="@style/TextAppearance.SaveAt.H2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/banner_promo_title"
                        android:textColor="@android:color/white" />
                    <TextView
                        style="@style/TextAppearance.SaveAt.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/banner_promo_subtitle"
                        android:textColor="@android:color/white"
                        android:alpha="0.7" />
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/spacing_s"
                        android:text="@string/order_now"
                        android:textAllCaps="false"
                        android:textColor="@color/text_h1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/accent_lime"
                        app:cornerRadius="@dimen/radius_pill" />
                </LinearLayout>
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="@dimen/spacing_m"
                    android:scaleType="centerInside"
                    android:contentDescription="@string/banner_promo_title"
                    android:src="@drawable/ic_local_shipping_rounded" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Categories chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_section"
            android:scrollbars="none">
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/categoriesChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBoulangerie"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_bakery" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRestaurant"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_restaurant" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEpicerie"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_grocery" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Section Commerces proches -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_l"
            android:gravity="center_vertical">

            <TextView
                style="@style/TextAppearance.SaveAt.H2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/commerces_nearby" />

            <TextView
                style="@style/TextAppearance.SaveAt.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/see_more" />
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerCommerces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal"
            tools:listitem="@layout/item_commerce_card" />

        <!-- Section Paniers du moment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_l"
            android:gravity="center_vertical">

            <TextView
                style="@style/TextAppearance.SaveAt.H2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/paniers_available" />

            <TextView
                style="@style/TextAppearance.SaveAt.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/see_more" />
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPaniers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="100dp"
            tools:listitem="@layout/item_panier_card"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
